RewriteEngine On
RewriteBase /ticketing/

# Disable caching for index.html (SPA entry point)
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# Disable caching for API responses
<If "%{REQUEST_URI} =~ m#^/ticketing/api/#">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</If>

# Direct access to existing files (uploads, static assets, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Direct access to existing directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API requests -> PHP front controller (skip uploads and cron/seed scripts)
RewriteRule ^api/uploads/ - [L]
RewriteRule ^api/cron/ - [L]
RewriteRule ^api/seed/ - [L]
RewriteRule ^api/migrations/ - [L]
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# React SPA fallback (everything else -> index.html)
RewriteRule ^ index.html [L]
