RewriteEngine On
RewriteBase /ticketing/

# Disable caching for HTML and API responses
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# Fallback: disable caching via mod_expires
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Direct access to existing files (uploads, static assets, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Direct access to existing directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API requests -> PHP front controller (skip uploads and cron/seed scripts)
RewriteRule ^api/uploads/ - [L]
RewriteRule ^api/cron/ - [L]
RewriteRule ^api/seed/ - [L]
RewriteRule ^api/migrations/ - [L]
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# React SPA fallback (everything else -> index.html)
RewriteRule ^ index.html [L]
