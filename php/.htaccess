RewriteEngine On
RewriteBase /ticketing/

# Block access to sensitive files
<FilesMatch "\.(md|env|enc|json|log|sql|sh|gitignore)$">
  Require all denied
</FilesMatch>
<FilesMatch "^(composer\.json|config\.enc)$">
  Require all denied
</FilesMatch>

# Security headers for all responses
<IfModule mod_headers.c>
  Header set X-Frame-Options "DENY"
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self'; frame-ancestors 'none'"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header set Cache-Control "no-cache, no-store, must-revalidate, private"
  Header set Pragma "no-cache"
  Header set Expires "0"
</IfModule>

# Fallback: disable caching via mod_expires
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Direct access to existing files (uploads, static assets, etc.)
# BUT exclude _app.html so it's never served directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_URI} !_app\.html$
RewriteRule ^ - [L]

# Direct access to existing directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API requests -> PHP front controller (skip uploads and cron/seed scripts)
RewriteRule ^api/uploads/ - [L]
RewriteRule ^api/cron/ - [L]
RewriteRule ^api/seed/ - [L]
RewriteRule ^api/migrations/ - [L]
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# React SPA fallback — append unique query string to bust Aruba CDN cache
RewriteCond %{QUERY_STRING} !_cb=
RewriteRule ^ index.php?_cb=%{TIME} [QSA,L]

# If already has _cb param, serve normally
RewriteRule ^ index.php [QSA,L]
